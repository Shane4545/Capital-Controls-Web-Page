<Program Name="Motor_Control" TestEdits="false" MainRoutineName="Motor_Control_Main" Disabled="false" UseAsFolder="false">
<Tags>
<Tag Name="Hydro_Tmr" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Data Format="L5K">
<![CDATA[[1105715,5000,0]]]>
</Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="5000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Motor_Start_Delay" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Delay while a motor is first started to prevent high current from multiple motor started together]]>
</Description>
<Data Format="L5K">
<![CDATA[[3158475,10000,0]]]>
</Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="10000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Other_Motor_Starting" TagType="Base" DataType="BOOL" Radix="Decimal" Constant="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Used in logic to determine a motor was just started and to prevent High current if another motor is started]]>
</Description>
<Data Format="L5K">
<![CDATA[0]]>
</Data>
<Data Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</Data>
</Tag>
</Tags>
<Routines>
<Routine Name="Motor_Control_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Motor_Main Routine

This routine is used to call subroutine required to 
manipulate all data related to motor start/stop and failure.
It also handles motor runtime and the ability to return to automatic
mode after an operator set delay when left in manual. In a power failure the motor waits for the power up sequence 
number to reach its number before starting.
  
//set motor start delay 
//this delay delays the start of a motor if another one just started]]>
</Comment>
<Text>
<![CDATA[LT(Powerup_Sequence,100)XIC(Pulse_Seconds)ADD(Powerup_Sequence,1,Powerup_Sequence);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[The powerup sequence is reset on the PLC first cycle

The power fail status or no power available is also used on this rung to reset the power up sequence so the motor will not try to run during power failure and get a fail to start alarm that will lock them
 ]]>
</Comment>
<Text>
<![CDATA[XIO(FirstCycle_Motor_Control_DN)[MOVE(0,Powerup_Sequence) ,OTU(Other_Motor_Starting) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[When a motor is started the bit
Other_Motor_Starting
is triggered and prevent any other motor from starting until the Motor_Start_Dekay timer expires
THe timer Preset value is controlled by the motor being started.
]]>
</Comment>
<Text>
<![CDATA[XIC(Motor_Start_Delay.DN)OTU(Other_Motor_Starting);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(Other_Motor_Starting)TON(Motor_Start_Delay,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[JSR(T7_Motor_Control_Main,0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[OTU(Operator_Gen_Alm_Reset);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[OTE(FirstCycle_Motor_Control_DN);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="T7_Motor_Control_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[P101 - PUMP 101]]>
</Comment>
<Text>
<![CDATA[Motor_Ctrl(P01,P01_AUTO_DI,P01_RUNNING_DI,OFF,P01_TEMPLEAK_XA.Active,P01_ESTOP_XA.Active,OFF,P01_VFD_FAULT_XA.Active,OFF,OFF,OFF,Other_Motor_Starting,Pulse_Day,FirstCycle_Motor_Control_DN,Powerup_Sequence,Operator_Gen_Alm_Reset,TimeCycle);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(P01.Run_Cmd)OTE(PUMP101_START_DO);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[If motor Starting then latch tag and set starting delay]]>
</Comment>
<Text>
<![CDATA[XIC(P01.Motor_Starting)[OTL(Other_Motor_Starting) ,MUL(P01.Starting_Time,1000,Motor_Start_Delay.PRE) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[P102 - PUMP 102]]>
</Comment>
<Text>
<![CDATA[Motor_Ctrl(P02,P02_AUTO_DI,P02_RUNNING_DI,OFF,P02_TEMPLEAK_XA.Active,P02_ESTOP_XA.Active,OFF,P02_VFD_FAULT_XA.Active,OFF,OFF,OFF,Other_Motor_Starting,Pulse_Day,FirstCycle_Motor_Control_DN,Powerup_Sequence,Operator_Gen_Alm_Reset,TimeCycle);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(P02.Run_Cmd)OTE(PUMP102_START_DO);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[If motor Starting then latch tag and set starting delay]]>
</Comment>
<Text>
<![CDATA[XIC(P02.Motor_Starting)[OTL(Other_Motor_Starting) ,MUL(P02.Starting_Time,1000,Motor_Start_Delay.PRE) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
