<![CDATA[Alarm_Ctrl(LIT001_LO_WARN,LIT001.LO_WARN_Raw,Dialer_Reset_Enable,Operator_Gen_Alm_Reset,Operator_Alarm_Ack,Total_Dialer_Channel,BUZZER_TRIGGERED,ALARM_PAGE_SCADA,Alarm_array,total_alarm);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[LIT001_LO_ALM - Wet Well Level Low Limit Alarm
ALARM ENABLED BY SYSTEM LOGIC
(ON IF NOT USED)]]>
</Comment>
<Text>
<![CDATA[XIC(ON)OTE(LIT001_LO_ALM.Sys_Ena);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[LIT001_LO_ALM - Wet Well Level Low Limit Alarm]]>
</Comment>
<Text>
<![CDATA[Alarm_Ctrl(LIT001_LO_ALM,LIT001.LO_ALM_Raw,Dialer_Reset_Enable,Operator_Gen_Alm_Reset,Operator_Alarm_Ack,Total_Dialer_Channel,BUZZER_TRIGGERED,ALARM_PAGE_SCADA,Alarm_array,total_alarm);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
