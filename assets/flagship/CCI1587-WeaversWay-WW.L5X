<Text>
<![CDATA[Alarm_Ctrl(LIT001_HI_ALM,LIT001.HI_ALM_Raw,Dialer_Reset_Enable,Operator_Gen_Alm_Reset,Operator_Alarm_Ack,Total_Dialer_Channel,BUZZER_TRIGGERED,ALARM_PAGE_SCADA,Alarm_array,total_alarm);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
