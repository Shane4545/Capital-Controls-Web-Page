<Routines>
<Routine Name="Clear_report" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[SBR();]]>
</Line>
<Line Number="1">
<![CDATA[]]>
</Line>
<Line Number="2">
<![CDATA[]]>
</Line>
<Line Number="3">
<![CDATA[For Rows := 0 to Report_Day_Qty-1 Do]]>
</Line>
<Line Number="4">
<![CDATA[	Report[Rows].Time.Year := 0;]]>
</Line>
<Line Number="5">
<![CDATA[	Report[Rows].Time.Month := 0;]]>
</Line>
<Line Number="6">
<![CDATA[	Report[Rows].Time.Day := 0;]]>
</Line>
<Line Number="7">
<![CDATA[	Report[Rows].Time.Hour := 0;]]>
</Line>
<Line Number="8">
<![CDATA[	Report[Rows].Time.Minute := 0;]]>
</Line>
<Line Number="9">
<![CDATA[	Report[Rows].Time.Second := 0;]]>
</Line>
<Line Number="10">
<![CDATA[]]>
</Line>
<Line Number="11">
<![CDATA[	FOR ReportIndex := 0 to Number_Of_Report_Item-1 DO]]>
</Line>
<Line Number="12">
<![CDATA[		Report[Rows].Data[ReportIndex].Min := 0;]]>
</Line>
<Line Number="13">
<![CDATA[		Report[Rows].Data[ReportIndex].Max := 0;]]>
</Line>
<Line Number="14">
<![CDATA[		Report[Rows].Data[ReportIndex].MinT_Hour := 0;]]>
</Line>
<Line Number="15">
<![CDATA[		Report[Rows].Data[ReportIndex].MaxT_Hour := 0;]]>
</Line>
<Line Number="16">
<![CDATA[		Report[Rows].Data[ReportIndex].MinT_min := 0;]]>
</Line>
<Line Number="17">
<![CDATA[		Report[Rows].Data[ReportIndex].MaxT_min := 0;]]>
</Line>
<Line Number="18">
<![CDATA[		Report[Rows].Data[ReportIndex].Tot := 0;]]>
</Line>
<Line Number="19">
<![CDATA[		Report[Rows].Data[ReportIndex].Acc_T := 0;]]>
</Line>
<Line Number="20">
<![CDATA[		Report[Rows].Data[ReportIndex].Valid := 0;]]>
</Line>
<Line Number="21">
<![CDATA[	END_FOR;]]>
</Line>
<Line Number="22">
<![CDATA[end_for;]]>
</Line>
<Line Number="23">
<![CDATA[]]>
</Line>
<Line Number="24">
<![CDATA[RET();]]>
</Line>
</STContent>
</Routine>
<Routine Name="T10_Analog_Report_Sub" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[SBR(AnalogValue, Not_Valid, CalculationEnable, ReportIndex);]]>
</Line>
<Line Number="1">
<![CDATA[]]>
</Line>
<Line Number="2">
<![CDATA[]]>
</Line>
<Line Number="3">
<![CDATA[(* only calculate if it is enabled *)]]>
</Line>
<Line Number="4">
<![CDATA[IF CalculationEnable THEN]]>
</Line>
<Line Number="5">
<![CDATA[	IF Report[ReportRow].Data[ReportIndex].Acc_T = 0 THEN]]>
</Line>
<Line Number="6">
<![CDATA[		Report[ReportRow].Data[ReportIndex].Max := AnalogValue;]]>
</Line>
<Line Number="7">
<![CDATA[		Report[ReportRow].Data[ReportIndex].Min := AnalogValue;]]>
</Line>
<Line Number="8">
<![CDATA[		Report[ReportRow].Data[ReportIndex].MinT_min := DateTime[4]; //Minute]]>
</Line>
<Line Number="9">
<![CDATA[		Report[ReportRow].Data[ReportIndex].MaxT_min := DateTime[4];]]>
</Line>
<Line Number="10">
<![CDATA[		Report[ReportRow].Data[ReportIndex].MinT_Hour := DateTime[3]; //Hour]]>
</Line>
<Line Number="11">
<![CDATA[		Report[ReportRow].Data[ReportIndex].MaxT_Hour := DateTime[3];]]>
</Line>
<Line Number="12">
<![CDATA[	ELSE]]>
</Line>
<Line Number="13">
<![CDATA[		IF AnalogValue < Report[ReportRow].Data[ReportIndex].Min THEN]]>
</Line>
<Line Number="14">
<![CDATA[		    Report[ReportRow].Data[ReportIndex].Min := AnalogValue;]]>
</Line>
<Line Number="15">
<![CDATA[			Report[ReportRow].Data[ReportIndex].MinT_Hour := DateTime[3];]]>
</Line>
<Line Number="16">
<![CDATA[			Report[ReportRow].Data[ReportIndex].MinT_min := DateTime[4];]]>
</Line>
<Line Number="17">
<![CDATA[		ELSIF AnalogValue > Report[ReportRow].Data[ReportIndex].Max THEN]]>
</Line>
<Line Number="18">
<![CDATA[		    Report[ReportRow].Data[ReportIndex].Max := AnalogValue;]]>
</Line>
<Line Number="19">
<![CDATA[			Report[ReportRow].Data[ReportIndex].MaxT_Hour := DateTime[3];]]>
</Line>
<Line Number="20">
<![CDATA[			Report[ReportRow].Data[ReportIndex].MaxT_min := DateTime[4];]]>
</Line>
<Line Number="21">
<![CDATA[		END_IF;]]>
</Line>
<Line Number="22">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="23">
<![CDATA[	Report[ReportRow].Data[ReportIndex].Tot := Report[ReportRow].Data[ReportIndex].Tot + TimeCycle / 1000 * AnalogValue;]]>
</Line>
<Line Number="24">
<![CDATA[	Report[ReportRow].Data[ReportIndex].Acc_T := Report[ReportRow].Data[ReportIndex].Acc_T + TimeCycle / 1000;]]>
</Line>
<Line Number="25">
<![CDATA[	]]>
</Line>
<Line Number="26">
<![CDATA[	IF Report[ReportRow].Data[ReportIndex].Acc_T > 0 then]]>
</Line>
<Line Number="27">
<![CDATA[		Report[ReportRow].Data[ReportIndex].Avg := Report[ReportRow].Data[ReportIndex].Tot/Report[ReportRow].Data[ReportIndex].Acc_T;]]>
</Line>
<Line Number="28">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="29">
<![CDATA[		]]>
</Line>
<Line Number="30">
<![CDATA[	IF Not_Valid THEN]]>
</Line>
<Line Number="31">
<![CDATA[		Report[ReportRow].Data[ReportIndex].Valid := 0;]]>
</Line>
<Line Number="32">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="33">
<![CDATA[END_IF;]]>
</Line>
<Line Number="34">
<![CDATA[]]>
</Line>
<Line Number="35">
<![CDATA[RET();]]>
</Line>
</STContent>
</Routine>
<Routine Name="T10_Main_Report" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[(*]]>
</Line>
<Line Number="1">
<![CDATA[THIS ROUTINE IS USED TO COLLECT ON AN HOURLY BASIS THE FOLLOWING INFO]]>
</Line>
<Line Number="2">
<![CDATA[]]>
</Line>
<Line Number="3">
<![CDATA[MINVAL/MINTIME/MAXVAL/MAXTIME/TOTAL FOR ANALOG VALUE]]>
</Line>
<Line Number="4">
<![CDATA[MOTOR RUNTIME]]>
</Line>
<Line Number="5">
<![CDATA[DAILY TOTAL FOR CYCLES AND OTHER ONCE A DAY VALUE]]>
</Line>
<Line Number="6">
<![CDATA[]]>
</Line>
<Line Number="7">
<![CDATA[*)]]>
</Line>
<Line Number="8">
<![CDATA[]]>
</Line>
<Line Number="9">
<![CDATA[If not FirstCycle_Report_DN then	]]>
</Line>
<Line Number="10">
<![CDATA[	//Determine the size of arrays]]>
</Line>
<Line Number="11">
<![CDATA[	SIZE(Report[0],0,REPORT_ARRAY_SIZE);]]>
</Line>
<Line Number="12">
<![CDATA[	SIZE(Report[0].Data[0],0,REPORT_DATA_ARRAY_SIZE);]]>
</Line>
<Line Number="13">
<![CDATA[end_if;]]>
</Line>
<Line Number="14">
<![CDATA[]]>
</Line>
<Line Number="15">
<![CDATA[]]>
</Line>
<Line Number="16">
<![CDATA[]]>
</Line>
<Line Number="17">
<![CDATA[]]>
</Line>
<Line Number="18">
<![CDATA[]]>
</Line>
<Line Number="19">
<![CDATA[if Clear_all_Data then]]>
</Line>
<Line Number="20">
<![CDATA[	JSR (Clear_report);]]>
</Line>
<Line Number="21">
<![CDATA[	ReportRow := 0;]]>
</Line>
<Line Number="22">
<![CDATA[	Clear_all_Data := OFF;]]>
</Line>
<Line Number="23">
<![CDATA[end_if;]]>
</Line>
<Line Number="24">
<![CDATA[]]>
</Line>
<Line Number="25">
<![CDATA[//THIS IS THE NUMBER OF REPORT ITEMS TO BE SAVED]]>
</Line>
<Line Number="26">
<![CDATA[Number_Of_Report_Item := 8;]]>
</Line>
<Line Number="27">
<![CDATA[]]>
</Line>
<Line Number="28">
<![CDATA[// Confirm number is smaller than array sizes]]>
</Line>
<Line Number="29">
<![CDATA[if Number_Of_Report_Item > REPORT_DATA_ARRAY_SIZE then]]>
</Line>
<Line Number="30">
<![CDATA[	Number_Of_Report_Item := REPORT_DATA_ARRAY_SIZE;]]>
</Line>
<Line Number="31">
<![CDATA[end_if;]]>
</Line>
<Line Number="32">
<![CDATA[	]]>
</Line>
<Line Number="33">
<![CDATA[//THIS IS THE NUMBER OF SAVED HOURS or DAYS AVAILABLE]]>
</Line>
<Line Number="34">
<![CDATA[Report_Day_Qty := 200;]]>
</Line>
<Line Number="35">
<![CDATA[if Report_Day_Qty > REPORT_ARRAY_SIZE then]]>
</Line>
<Line Number="36">
<![CDATA[Report_Day_Qty := REPORT_ARRAY_SIZE;]]>
</Line>
<Line Number="37">
<![CDATA[end_if;]]>
</Line>
<Line Number="38">
<![CDATA[]]>
</Line>
<Line Number="39">
<![CDATA[]]>
</Line>
<Line Number="40">
<![CDATA[]]>
</Line>
<Line Number="41">
<![CDATA[		(* Place Logic HERE *)]]>
</Line>
<Line Number="42">
<![CDATA[]]>
</Line>
<Line Number="43">
<![CDATA[]]>
</Line>
<Line Number="44">
<![CDATA[]]>
</Line>
<Line Number="45">
<![CDATA[]]>
</Line>
<Line Number="46">
<![CDATA[]]>
</Line>
<Line Number="47">
<![CDATA[]]>
</Line>
<Line Number="48">
<![CDATA[]]>
</Line>
<Line Number="49">
<![CDATA[]]>
</Line>
<Line Number="50">
<![CDATA[IF Pulse_Day or TEST_REPORT THEN // Hour Pulse could be used instead]]>
</Line>
<Line Number="51">
<![CDATA[	JSR(T10_Save_Report_Sub);]]>
</Line>
<Line Number="52">
<![CDATA[END_IF;]]>
</Line>
<Line Number="53">
<![CDATA[]]>
</Line>
<Line Number="54">
<![CDATA[]]>
</Line>
<Line Number="55">
<![CDATA[]]>
</Line>
<Line Number="56">
<![CDATA[for i := 0 to 6 by 1 do]]>
</Line>
<Line Number="57">
<![CDATA[	Last_DateTime[i] := DateTime[i];]]>
</Line>
<Line Number="58">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="59">
<![CDATA[]]>
</Line>
<Line Number="60">
<![CDATA[]]>
</Line>
<Line Number="61">
<![CDATA[//VERIFY POINTER WILL BE WITHIN THE ARRAY]]>
</Line>
<Line Number="62">
<![CDATA[if Report_Selected_Previous_Day > Report_Day_Qty - 1 then Report_Selected_Previous_Day := Report_Day_Qty - 1;end_if;]]>
</Line>
<Line Number="63">
<![CDATA[if Report_Selected_Previous_Day < 0 then Report_Selected_Previous_Day := 0;end_if;]]>
</Line>
<Line Number="64">
<![CDATA[]]>
</Line>
<Line Number="65">
<![CDATA[//WHEN USING MS ACCESS REPORT THE POINTER OF TODAY IS NOT ALWAYS AT ZERO AND THEREFORE]]>
</Line>
<Line Number="66">
<![CDATA[//IT IS REQUIRED TO CALCULATE WHERE IN THE TABLE THE PREVIOUS DAYS ARE.]]>
</Line>
<Line Number="67">
<![CDATA[//THE FOLLOWING CODE DETERMINES WHERE IN THE ARRAY THE REQUESTED DAY IS]]>
</Line>
<Line Number="68">
<![CDATA[]]>
</Line>
<Line Number="69">
<![CDATA[If Access_Report then]]>
</Line>
<Line Number="70">
<![CDATA[	if ReportRow < Report_Selected_Previous_Day then]]>
</Line>
<Line Number="71">
<![CDATA[		report_pointer := Report_Day_Qty + ReportRow - Report_Selected_Previous_Day;]]>
</Line>
<Line Number="72">
<![CDATA[	else]]>
</Line>
<Line Number="73">
<![CDATA[		report_pointer := ReportRow - Report_Selected_Previous_Day;]]>
</Line>
<Line Number="74">
<![CDATA[	end_if;]]>
</Line>
<Line Number="75">
<![CDATA[else]]>
</Line>
<Line Number="76">
<![CDATA[	report_pointer := Report_Selected_Previous_Day;]]>
</Line>
<Line Number="77">
<![CDATA[end_if;]]>
</Line>
<Line Number="78">
<![CDATA[]]>
</Line>
<Line Number="79">
<![CDATA[//THIS ARRAY IS USED TO DISPLAY A PREVIOUS DAY]]>
</Line>
<Line Number="80">
<![CDATA[FOR ReportIndex := 0 to Number_Of_Report_Item-1 DO]]>
</Line>
<Line Number="81">
<![CDATA[	Report_Day.Data[ReportIndex].Min := Report[report_pointer].Data[ReportIndex].Min;]]>
</Line>
<Line Number="82">
<![CDATA[	Report_Day.Data[ReportIndex].Max := Report[report_pointer].Data[ReportIndex].Max;]]>
</Line>
<Line Number="83">
<![CDATA[	Report_Day.Data[ReportIndex].MinT_Hour := Report[report_pointer].Data[ReportIndex].MinT_Hour;]]>
</Line>
<Line Number="84">
<![CDATA[	Report_Day.Data[ReportIndex].MaxT_Hour := Report[report_pointer].Data[ReportIndex].MaxT_Hour;]]>
</Line>
<Line Number="85">
<![CDATA[	Report_Day.Data[ReportIndex].MinT_min := Report[report_pointer].Data[ReportIndex].MinT_min;]]>
</Line>
<Line Number="86">
<![CDATA[	Report_Day.Data[ReportIndex].MaxT_min := Report[report_pointer].Data[ReportIndex].MaxT_min;]]>
</Line>
<Line Number="87">
<![CDATA[	Report_Day.Data[ReportIndex].NofStart := Report[report_pointer].Data[ReportIndex].NofStart;]]>
</Line>
<Line Number="88">
<![CDATA[	Report_Day.Data[ReportIndex].Tot := Report[report_pointer].Data[ReportIndex].Tot ;]]>
</Line>
<Line Number="89">
<![CDATA[	if Report[report_pointer].Data[ReportIndex].Acc_T > 0 then]]>
</Line>
<Line Number="90">
<![CDATA[		Report_Day.Data[ReportIndex].Avg := Report[report_pointer].Data[ReportIndex].Tot/Report[report_pointer].Data[ReportIndex].Acc_T;]]>
</Line>
<Line Number="91">
<![CDATA[	else]]>
</Line>
<Line Number="92">
<![CDATA[		Report_Day.Data[ReportIndex].Avg := 0;]]>
</Line>
<Line Number="93">
<![CDATA[	end_if;]]>
</Line>
<Line Number="94">
<![CDATA[	Report_Day.Data[ReportIndex].Acc_T := Report[report_pointer].Data[ReportIndex].Acc_T;]]>
</Line>
<Line Number="95">
<![CDATA[	Report_Day.Data[ReportIndex].Valid := Report[report_pointer].Data[ReportIndex].Valid;]]>
</Line>
<Line Number="96">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="97">
<![CDATA[if Report_Selected_Previous_Day =0 then]]>
</Line>
<Line Number="98">
<![CDATA[	Report_Day.Time.Year := DateTime[0];]]>
</Line>
<Line Number="99">
<![CDATA[	Report_Day.Time.Month := DateTime[1];]]>
</Line>
<Line Number="100">
<![CDATA[	Report_Day.Time.Day := DateTime[2];]]>
</Line>
<Line Number="101">
<![CDATA[	Report_Day.Time.Hour := DateTime[3];]]>
</Line>
<Line Number="102">
<![CDATA[	Report_Day.Time.Minute := DateTime[4];]]>
</Line>
<Line Number="103">
<![CDATA[	Report_Day.Time.Second := DateTime[5];]]>
</Line>
<Line Number="104">
<![CDATA[else]]>
</Line>
<Line Number="105">
<![CDATA[	Report_Day.Time.Year := Report[report_pointer].Time.Year;]]>
</Line>
<Line Number="106">
<![CDATA[	Report_Day.Time.Month := Report[report_pointer].Time.Month;]]>
</Line>
<Line Number="107">
<![CDATA[	Report_Day.Time.Day := Report[report_pointer].Time.Day;]]>
</Line>
<Line Number="108">
<![CDATA[	Report_Day.Time.Hour := Report[report_pointer].Time.Hour;]]>
</Line>
<Line Number="109">
<![CDATA[	Report_Day.Time.Minute := Report[report_pointer].Time.Minute;]]>
</Line>
<Line Number="110">
<![CDATA[	Report_Day.Time.Second := Report[report_pointer].Time.Second;]]>
</Line>
<Line Number="111">
<![CDATA[end_if;]]>
</Line>
<Line Number="112">
<![CDATA[]]>
</Line>
<Line Number="113">
<![CDATA[TEST_REPORT  := OFF;]]>
</Line>
<Line Number="114">
<![CDATA[]]>
</Line>
<Line Number="115">
<![CDATA[FirstCycle_Report_DN := ON;]]>
</Line>
</STContent>
</Routine>
<Routine Name="T10_Motor_Report_Sub" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[SBR(Valeur_Bool, ReportIndex);]]>
</Line>
<Line Number="1">
<![CDATA[]]>
</Line>
<Line Number="2">
<![CDATA[(* add the total *)]]>
</Line>
<Line Number="3">
<![CDATA[if Valeur_Bool then]]>
</Line>
<Line Number="4">
<![CDATA[	Report[ReportRow].Data[ReportIndex].Tot := Report[ReportRow].Data[ReportIndex].Tot + TimeCycle / 1000;]]>
</Line>
<Line Number="5">
<![CDATA[end_if;]]>
</Line>
<Line Number="6">
<![CDATA[]]>
</Line>
<Line Number="7">
<![CDATA[(* add the time *)]]>
</Line>
<Line Number="8">
<![CDATA[Report[ReportRow].Data[ReportIndex].Acc_T := Report[ReportRow].Data[ReportIndex].Acc_T + TimeCycle / 1000;]]>
</Line>
<Line Number="9">
<![CDATA[]]>
</Line>
<Line Number="10">
<![CDATA[(*If motor running then add one to max values as a count of number of starts*)]]>
</Line>
<Line Number="11">
<![CDATA[if Valeur_Bool and not Report[ReportRow].Data[ReportIndex].Valid then]]>
</Line>
<Line Number="12">
<![CDATA[	Report[ReportRow].Data[ReportIndex].NofStart := Report[ReportRow].Data[ReportIndex].NofStart +1;]]>
</Line>
<Line Number="13">
<![CDATA[end_if;]]>
</Line>
<Line Number="14">
<![CDATA[]]>
</Line>
<Line Number="15">
<![CDATA[(*valid is used as the last status of the motor to determine if it was just being started*)]]>
</Line>
<Line Number="16">
<![CDATA[Report[ReportRow].Data[ReportIndex].Valid := Valeur_Bool;]]>
</Line>
<Line Number="17">
<![CDATA[RET();	]]>
</Line>
</STContent>
</Routine>
<Routine Name="T10_Save_Report_Sub" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[sbr();]]>
</Line>
<Line Number="1">
<![CDATA[Report[0].Time.Year := Last_DateTime[0];]]>
</Line>
<Line Number="2">
<![CDATA[Report[0].Time.Month := Last_DateTime[1];]]>
</Line>
<Line Number="3">
<![CDATA[Report[0].Time.Day := Last_DateTime[2];]]>
</Line>
<Line Number="4">
<![CDATA[Report[0].Time.Hour := Last_DateTime[3];]]>
</Line>
<Line Number="5">
<![CDATA[Report[0].Time.Minute := Last_DateTime[4];]]>
</Line>
<Line Number="6">
<![CDATA[Report[0].Time.Second := Last_DateTime[5];]]>
</Line>
<Line Number="7">
<![CDATA[]]>
</Line>
<Line Number="8">
<![CDATA[for i := Report_Day_Qty - 1 TO 1 by -1 DO]]>
</Line>
<Line Number="9">
<![CDATA[	FOR ReportIndex := 0 to Number_Of_Report_Item-1 DO]]>
</Line>
<Line Number="10">
<![CDATA[		Report[i].Data[ReportIndex].Min := Report[i-1].Data[ReportIndex].Min;]]>
</Line>
<Line Number="11">
<![CDATA[		Report[i].Data[ReportIndex].Max := Report[i-1].Data[ReportIndex].Max;]]>
</Line>
<Line Number="12">
<![CDATA[		Report[i].Data[ReportIndex].MinT_Hour := Report[i-1].Data[ReportIndex].MinT_Hour;]]>
</Line>
<Line Number="13">
<![CDATA[		Report[i].Data[ReportIndex].MaxT_Hour := Report[i-1].Data[ReportIndex].MaxT_Hour;]]>
</Line>
<Line Number="14">
<![CDATA[		Report[i].Data[ReportIndex].MinT_min := Report[i-1].Data[ReportIndex].MinT_min;]]>
</Line>
<Line Number="15">
<![CDATA[		Report[i].Data[ReportIndex].MaxT_min := Report[i-1].Data[ReportIndex].MaxT_min;]]>
</Line>
<Line Number="16">
<![CDATA[		Report[i].Data[ReportIndex].Tot := Report[i-1].Data[ReportIndex].Tot ;]]>
</Line>
<Line Number="17">
<![CDATA[		Report[i].Data[ReportIndex].Acc_T := Report[i-1].Data[ReportIndex].Acc_T;]]>
</Line>
<Line Number="18">
<![CDATA[		Report[i].Data[ReportIndex].NofStart := Report[i-1].Data[ReportIndex].NofStart;]]>
</Line>
<Line Number="19">
<![CDATA[		Report[i].Data[ReportIndex].Valid := Report[i-1].Data[ReportIndex].Valid;]]>
</Line>
<Line Number="20">
<![CDATA[	END_FOR;]]>
</Line>
<Line Number="21">
<![CDATA[		Report[i].Time.Year := Report[i-1].Time.Year;]]>
</Line>
<Line Number="22">
<![CDATA[		Report[i].Time.Month := Report[i-1].Time.Month;]]>
</Line>
<Line Number="23">
<![CDATA[		Report[i].Time.Day := Report[i-1].Time.Day;]]>
</Line>
<Line Number="24">
<![CDATA[		Report[i].Time.Hour := Report[i-1].Time.Hour;]]>
</Line>
<Line Number="25">
<![CDATA[		Report[i].Time.Minute := Report[i-1].Time.Minute;]]>
</Line>
<Line Number="26">
<![CDATA[		Report[i].Time.Second := Report[i-1].Time.Second;]]>
</Line>
<Line Number="27">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="28">
<![CDATA[]]>
</Line>
<Line Number="29">
<![CDATA[]]>
</Line>
<Line Number="30">
<![CDATA[]]>
</Line>
<Line Number="31">
<![CDATA[Report[0].Time.Year := 0;]]>
</Line>
<Line Number="32">
<![CDATA[Report[0].Time.Month := 0;]]>
</Line>
<Line Number="33">
<![CDATA[Report[0].Time.Day := 0;]]>
</Line>
<Line Number="34">
<![CDATA[Report[0].Time.Hour := 0;]]>
</Line>
<Line Number="35">
<![CDATA[Report[0].Time.Minute := 0;]]>
</Line>
<Line Number="36">
<![CDATA[Report[0].Time.Second := 0;]]>
</Line>
<Line Number="37">
<![CDATA[]]>
</Line>
<Line Number="38">
<![CDATA[FOR ReportIndex := 0 to Number_Of_Report_Item-1 DO]]>
</Line>
<Line Number="39">
<![CDATA[	Report[0].Data[ReportIndex].Min := 0;]]>
</Line>
<Line Number="40">
<![CDATA[	Report[0].Data[ReportIndex].Max := 0;]]>
</Line>
<Line Number="41">
<![CDATA[	Report[0].Data[ReportIndex].MinT_Hour := 0;]]>
</Line>
<Line Number="42">
<![CDATA[	Report[0].Data[ReportIndex].MaxT_Hour := 0;]]>
</Line>
<Line Number="43">
<![CDATA[	Report[0].Data[ReportIndex].MinT_min := 0;]]>
</Line>
<Line Number="44">
<![CDATA[	Report[0].Data[ReportIndex].MaxT_min := 0;]]>
</Line>
<Line Number="45">
<![CDATA[	Report[0].Data[ReportIndex].Tot := 0;]]>
</Line>
<Line Number="46">
<![CDATA[	Report[0].Data[ReportIndex].Acc_T := 0;]]>
</Line>
<Line Number="47">
<![CDATA[	Report[0].Data[ReportIndex].NofStart := 0;]]>
</Line>
<Line Number="48">
<![CDATA[	Report[0].Data[ReportIndex].Valid := 1;]]>
</Line>
<Line Number="49">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="50">
<![CDATA[]]>
</Line>
<Line Number="51">
<![CDATA[]]>
</Line>
<Line Number="52">
<![CDATA[ret();]]>
</Line>
</STContent>
</Routine>
</Routines>
</Program>
<Program Name="Synchronisation" TestEdits="false" MainRoutineName="T0_Cycle_main_Revision_Info" Disabled="false" UseAsFolder="false">
<Tags>
<Tag Name="LastTimeCycle" TagType="Base" DataType="DINT" Radix="Decimal" Constant="false" ExternalAccess="Read/Write">
<Data Format="L5K">
<![CDATA[250]]>
</Data>
<Data Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="250"/>
</Data>
</Tag>
<Tag Name="Last_Cycle" TagType="Base" DataType="DINT" Radix="Decimal" Constant="false" ExternalAccess="Read/Write">
<Data Format="L5K">
<![CDATA[981270]]>
</Data>
<Data Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="981270"/>
</Data>
</Tag>
<Tag Name="Synchro_Timer" TagType="Base" DataType="FBD_TIMER" Constant="false" ExternalAccess="Read/Write">
<Data Format="L5K">
<![CDATA[[2,6,2100000000,981270,0,250,2212237,5632,1048576000,2,981270,6]]]>
</Data>
<Data Format="Decorated">
<Structure DataType="FBD_TIMER">
<DataValueMember Name="EnableIn" DataType="BOOL" Value="0"/>
<DataValueMember Name="TimerEnable" DataType="BOOL" Value="1"/>
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="2100000000"/>
<DataValueMember Name="Reset" DataType="BOOL" Value="0"/>
<DataValueMember Name="EnableOut" DataType="BOOL" Value="0"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="981270"/>
<DataValueMember Name="EN" DataType="BOOL" Value="1"/>
<DataValueMember Name="TT" DataType="BOOL" Value="1"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
<DataValueMember Name="Status" DataType="DINT" Radix="Hex" Value="16#0000_0000"/>
<DataValueMember Name="InstructFault" DataType="BOOL" Value="0"/>
<DataValueMember Name="PresetInv" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
</Tags>
<Routines>
<Routine Name="T0_Cycle_main_Revision_Info" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[(*]]>
</Line>
<Line Number="1">
<![CDATA[]]>
</Line>
<Line Number="2">
<![CDATA[Revision 1.0  - New template created using Add-On Instruction]]>
</Line>
<Line Number="3">
<![CDATA[Revision 5.0  - Duty rotation routine modified. Timers for motor_1_Stop_Tmr to motor_20_Stop_Tmr added to allow multiple duty group not to use same timers ]]>
</Line>
<Line Number="4">
<![CDATA[Revision 9.0  - Correction of PID add on block update time, min and max output]]>
</Line>
<Line Number="5">
<![CDATA[			  - Adding of uncommanded open and close for valve]]>
</Line>
<Line Number="6">
<![CDATA[			  - Adding of Fault_1 to valve block]]>
</Line>
<Line Number="7">
<![CDATA[			  - Adding of uncommanded start and stop for motor]]>
</Line>
<Line Number="8">
<![CDATA[Revision 10.0 - Modification of PID routine to include update time in add on ]]>
</Line>
<Line Number="9">
<![CDATA[Revision 11.0 - Adding of min and max limit to manual output]]>
</Line>
<Line Number="10">
<![CDATA[Revision 12.0 - Fixed Pulse_Month and added Pulse_Year]]>
</Line>
<Line Number="11">
<![CDATA[Revision 13.0 - Added ladder logic for inputs and outputs]]>
</Line>
<Line Number="12">
<![CDATA[Revision 14.0 - Modified sub routine Save_Report_Sub to save the value of the tag XXX.NofStart and reset it at the end of the day]]>
</Line>
<Line Number="13">
<![CDATA[Revision 15.0 - Modified Add-On logic Alarm_Ctrl for channel being reset if Dialer_Reset_Enable bit is ON. The dialer bit channel is reset and]]>
</Line>
<Line Number="14">
<![CDATA[				if the acknowledge delay is set bigger than 0 then it will dial again if time expires and alarm still present.]]>
</Line>
<Line Number="15">
<![CDATA[			  - MSAccess Report sub routine Removed. ]]>
</Line>
<Line Number="16">
<![CDATA[			  - Array is verified to confirm the size is not exceeded when setting day quantity or item quantity]]>
</Line>
<Line Number="17">
<![CDATA[			  - The Tag "SECOND_FLASHER" added. This provides an flasher ON for 1 second and OFF for one second]]>
</Line>
<Line Number="18">
<![CDATA[Revision 16.0 - Filter for process analog was adjusted so the minimum value to force to zero is not preventing the value to increase when it is smaller]]>
</Line>
<Line Number="19">
<![CDATA[Revision 17.0 - Remote status added for valve logic availability in the Add-On block]]>
</Line>
<Line Number="20">
<![CDATA[Revision 18.0 - Interlocks and faults added to Motor Control Logic to prevent fail to start stop while there is an interlock in place]]>
</Line>
<Line Number="21">
<![CDATA[ ]]>
</Line>
<Line Number="22">
<![CDATA[]]>
</Line>
<Line Number="23">
<![CDATA[*)]]>
</Line>
<Line Number="24">
<![CDATA[]]>
</Line>
<Line Number="25">
<![CDATA[]]>
</Line>
<Line Number="26">
<![CDATA[]]>
</Line>
<Line Number="27">
<![CDATA[(*]]>
</Line>
<Line Number="28">
<![CDATA[						Routine: Cycle_Main]]>
</Line>
<Line Number="29">
<![CDATA[]]>
</Line>
<Line Number="30">
<![CDATA[La routine suivante est utilisé pour ]]>
</Line>
<Line Number="31">
<![CDATA[calculer la duration du cycle du program "T1_Programme_Principal"]]>
</Line>
<Line Number="32">
<![CDATA[Cette valeur est utilisé pour les rapports.]]>
</Line>
<Line Number="33">
<![CDATA[]]>
</Line>
<Line Number="34">
<![CDATA[*)]]>
</Line>
<Line Number="35">
<![CDATA[//ON & OFF always confirmed]]>
</Line>
<Line Number="36">
<![CDATA[ON := 1;]]>
</Line>
<Line Number="37">
<![CDATA[OFF := 0;]]>
</Line>
<Line Number="38">
<![CDATA[]]>
</Line>
<Line Number="39">
<![CDATA[//Cycle time calculation]]>
</Line>
<Line Number="40">
<![CDATA[]]>
</Line>
<Line Number="41">
<![CDATA[GSV(Task,THIS,rate,TimeCycle2);//Get cycle time in microseconds]]>
</Line>
<Line Number="42">
<![CDATA[]]>
</Line>
<Line Number="43">
<![CDATA[TimeCycle:=TimeCycle2/1000; // calculate in miliseconds]]>
</Line>
<Line Number="44">
<![CDATA[]]>
</Line>
<Line Number="45">
<![CDATA[]]>
</Line>
<Line Number="46">
<![CDATA[if TimeCycle < 0 then]]>
</Line>
<Line Number="47">
<![CDATA[TimeCycle := LastTimeCycle;]]>
</Line>
<Line Number="48">
<![CDATA[end_if;]]>
</Line>
<Line Number="49">
<![CDATA[]]>
</Line>
<Line Number="50">
<![CDATA[LastTimeCycle := TimeCycle;]]>
</Line>
<Line Number="51">
<![CDATA[]]>
</Line>
<Line Number="52">
<![CDATA[//Lorsque la valeur est très grande on retourne a zero]]>
</Line>
<Line Number="53">
<![CDATA[If (Synchro_Timer.ACC > 2000000000 ) then]]>
</Line>
<Line Number="54">
<![CDATA[	Synchro_Timer.Reset := ON;]]>
</Line>
<Line Number="55">
<![CDATA[	TONR(Synchro_Timer);]]>
</Line>
<Line Number="56">
<![CDATA[	Synchro_Timer.Reset := OFF;]]>
</Line>
<Line Number="57">
<![CDATA[	TONR(Synchro_Timer);]]>
</Line>
<Line Number="58">
<![CDATA[	Last_Cycle:= 0;]]>
</Line>
<Line Number="59">
<![CDATA[end_if;]]>
</Line>
<Line Number="60">
<![CDATA[]]>
</Line>
<Line Number="61">
<![CDATA[//Registre de la date et l'heure]]>
</Line>
<Line Number="62">
<![CDATA[GSV( WALLCLOCKTIME, , LocalDateTime, DateTime[0] );]]>
</Line>
<Line Number="63">
<![CDATA[DateTime[3] := DateTime[3];]]>
</Line>
<Line Number="64">
<![CDATA[]]>
</Line>
<Line Number="65">
<![CDATA[if Set_PLC_Clock then]]>
</Line>
<Line Number="66">
<![CDATA[	Set_PLC_Clock := OFF;]]>
</Line>
<Line Number="67">
<![CDATA[	SSV( WALLCLOCKTIME, , LocalDateTime, New_PLC_DateTime[0] );]]>
</Line>
<Line Number="68">
<![CDATA[end_if;]]>
</Line>
<Line Number="69">
<![CDATA[]]>
</Line>
<Line Number="70">
<![CDATA[//synchronization des horologes par le SCADA a 2:00 AM]]>
</Line>
<Line Number="71">
<![CDATA[if Clock_sync then]]>
</Line>
<Line Number="72">
<![CDATA[	Clock_sync := OFF;]]>
</Line>
<Line Number="73">
<![CDATA[	DateTime[3] := 2;]]>
</Line>
<Line Number="74">
<![CDATA[	DateTime[4] := 0;]]>
</Line>
<Line Number="75">
<![CDATA[	DateTime[5] := 0;]]>
</Line>
<Line Number="76">
<![CDATA[	SSV( WALLCLOCKTIME, , LocalDateTime, DateTime[0] );]]>
</Line>
<Line Number="77">
<![CDATA[end_if;]]>
</Line>
<Line Number="78">
<![CDATA[]]>
</Line>
<Line Number="79">
<![CDATA[//Reset all the pulses - These pulses will be used throughout the logic as required]]>
</Line>
<Line Number="80">
<![CDATA[Pulse_Month := OFF;]]>
</Line>
<Line Number="81">
<![CDATA[Pulse_Year := OFF;]]>
</Line>
<Line Number="82">
<![CDATA[Pulse_Day := OFF;]]>
</Line>
<Line Number="83">
<![CDATA[Pulse_Hour := OFF;]]>
</Line>
<Line Number="84">
<![CDATA[Pulse_Min := OFF;]]>
</Line>
<Line Number="85">
<![CDATA[Pulse_Seconds := OFF;]]>
</Line>
<Line Number="86">
<![CDATA[]]>
</Line>
<Line Number="87">
<![CDATA[PreviousDateTime[6] := DateTime[6];]]>
</Line>
<Line Number="88">
<![CDATA[]]>
</Line>
<Line Number="89">
<![CDATA[]]>
</Line>
<Line Number="90">
<![CDATA[]]>
</Line>
<Line Number="91">
<![CDATA[//Set the pulse once the corresponding value changes]]>
</Line>
<Line Number="92">
<![CDATA[IF NOT (DateTime[0] = PreviousDateTime[0]) THEN]]>
</Line>
<Line Number="93">
<![CDATA[	Pulse_Year := ON;]]>
</Line>
<Line Number="94">
<![CDATA[	PreviousDateTime[0] := DateTime[0];]]>
</Line>
<Line Number="95">
<![CDATA[END_IF;]]>
</Line>
<Line Number="96">
<![CDATA[IF NOT (DateTime[1] = PreviousDateTime[1]) THEN]]>
</Line>
<Line Number="97">
<![CDATA[	Pulse_Month := ON;]]>
</Line>
<Line Number="98">
<![CDATA[	PreviousDateTime[1] := DateTime[1];]]>
</Line>
<Line Number="99">
<![CDATA[END_IF;]]>
</Line>
<Line Number="100">
<![CDATA[]]>
</Line>
<Line Number="101">
<![CDATA[IF NOT (DateTime[2] = PreviousDateTime[2]) THEN]]>
</Line>
<Line Number="102">
<![CDATA[	Pulse_Day := ON;]]>
</Line>
<Line Number="103">
<![CDATA[	PreviousDateTime[2] := DateTime[2];]]>
</Line>
<Line Number="104">
<![CDATA[END_IF;]]>
</Line>
<Line Number="105">
<![CDATA[]]>
</Line>
<Line Number="106">
<![CDATA[IF NOT (DateTime[3] = PreviousDateTime[3]) THEN]]>
</Line>
<Line Number="107">
<![CDATA[	Pulse_Hour := ON;]]>
</Line>
<Line Number="108">
<![CDATA[	PreviousDateTime[3] := DateTime[3];]]>
</Line>
<Line Number="109">
<![CDATA[END_IF;]]>
</Line>
<Line Number="110">
<![CDATA[]]>
</Line>
<Line Number="111">
<![CDATA[IF NOT (DateTime[4] = PreviousDateTime[4]) THEN]]>
</Line>
<Line Number="112">
<![CDATA[	Pulse_Min := ON;]]>
</Line>
<Line Number="113">
<![CDATA[	PreviousDateTime[4] := DateTime[4];]]>
</Line>
<Line Number="114">
<![CDATA[END_IF;]]>
</Line>
<Line Number="115">
<![CDATA[]]>
</Line>
<Line Number="116">
<![CDATA[IF NOT (DateTime[5] = PreviousDateTime[5]) THEN]]>
</Line>
<Line Number="117">
<![CDATA[	Pulse_Seconds := ON;]]>
</Line>
<Line Number="118">
<![CDATA[	PreviousDateTime[5] := DateTime[5];]]>
</Line>
<Line Number="119">
<![CDATA[END_IF;]]>
</Line>
<Line Number="120">
<![CDATA[]]>
</Line>
<Line Number="121">
<![CDATA[]]>
</Line>
<Line Number="122">
<![CDATA[//Chronometre for operator]]>
</Line>
<Line Number="123">
<![CDATA[IF Pulse_Seconds AND CHRONO_RUN THEN]]>
</Line>
<Line Number="124">
<![CDATA[	CHRONO := CHRONO + 1;]]>
</Line>
<Line Number="125">
<![CDATA[END_IF;]]>
</Line>
<Line Number="126">
<![CDATA[]]>
</Line>
<Line Number="127">
<![CDATA[IF CHRONO > 1000000 THEN]]>
</Line>
<Line Number="128">
<![CDATA[	CHRONO := 0;]]>
</Line>
<Line Number="129">
<![CDATA[END_IF;]]>
</Line>
<Line Number="130">
<![CDATA[]]>
</Line>
<Line Number="131">
<![CDATA[IF Pulse_Seconds then]]>
</Line>
<Line Number="132">
<![CDATA[	IF SECOND_FLASHER then SECOND_FLASHER := OFF;]]>
</Line>
<Line Number="133">
<![CDATA[	ELSE SECOND_FLASHER := ON;]]>
</Line>
<Line Number="134">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="135">
<![CDATA[END_IF;]]>
</Line>
<Line Number="136">
<![CDATA[]]>
</Line>
<Line Number="137">
<![CDATA[FirstCycle_Synchronisation_DN:=ON;]]>
</Line>
