<Routines>
<Routine Name="PowerUp_Main" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[// Lire le registre des fautes majeurs]]>
</Line>
<Line Number="1">
<![CDATA[GSV(PROGRAM, THIS, MAJORFAULTRECORD, Faute_Majeur.T_low);]]>
</Line>
<Line Number="2">
<![CDATA[//Remettre la faute à zero pour permettre au PLC de démarrer]]>
</Line>
<Line Number="3">
<![CDATA[Faute_Majeur.type := 0;]]>
</Line>
<Line Number="4">
<![CDATA[Faute_Majeur.code := 0;]]>
</Line>
<Line Number="5">
<![CDATA[//Ecrire les valveurs dans lea registre des fautes majeurs]]>
</Line>
<Line Number="6">
<![CDATA[SSV(PROGRAM, THIS, MAJORFAULTRECORD, Faute_Majeur.T_low);]]>
</Line>
<Line Number="7">
<![CDATA[//Créer les constantes ON et OFF]]>
</Line>
<Line Number="8">
<![CDATA[ON := 1;]]>
</Line>
<Line Number="9">
<![CDATA[OFF := 0;]]>
</Line>
<Line Number="10">
<![CDATA[//Les valwurs suivantes sont remis a zero et permette de completer un]]>
</Line>
<Line Number="11">
<![CDATA[//cycle d'initialisation après le démarage du PLC]]>
</Line>
<Line Number="12">
<![CDATA[FirstCycle_Synchronisation_DN :=OFF;]]>
</Line>
<Line Number="13">
<![CDATA[FirstCycle_Analog_Processing_DN := OFF;]]>
</Line>
<Line Number="14">
<![CDATA[FirstCycle_Alarm_Control_DN := OFF;]]>
</Line>
<Line Number="15">
<![CDATA[FirstCycle_Duty_Rotation_DN :=OFF;]]>
</Line>
<Line Number="16">
<![CDATA[FirstCycle_Motor_Control_DN := OFF;]]>
</Line>
<Line Number="17">
<![CDATA[FirstCycle_Analog_Control_DN := OFF;]]>
</Line>
<Line Number="18">
<![CDATA[FirstCycle_Valve_Control_DN := OFF;]]>
</Line>
<Line Number="19">
<![CDATA[FirstCycle_Digital_Control_DN := OFF;]]>
</Line>
<Line Number="20">
<![CDATA[FirstCycle_Report_DN := OFF;]]>
</Line>
<Line Number="21">
<![CDATA[FirstCycle_PID_Control_DN := OFF;]]>
</Line>
<Line Number="22">
<![CDATA[FirstCycle_Plant_Control_DN := OFF;]]>
</Line>
<Line Number="23">
<![CDATA[]]>
</Line>
<Line Number="24">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
</Routines>
</Program>
