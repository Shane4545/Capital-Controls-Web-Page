ALARM ENABLED BY SYSTEM LOGIC
(ON IF NOT USED)]]>
</Comment>
<Text>
<![CDATA[XIC(ON)OTE(LIT001_LO_WARN.Sys_Ena);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
