<Routines>
<Routine Name="Alarm_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Routine: Alarm_Main

This routine is used to call subroutine required to 
manipulate all data related to alarm handling


//initialise on first pass]]>
</Comment>
<Text>
<![CDATA[XIO(FirstCycle_Alarm_Control_DN)[OTU(Operator_Alarm_Reset_Dialer) ,OTU(Operator_Alarm_Ack) ,OTU(Operator_Gen_Alm_Reset) ,OTU(BUZZER_TRIGGERED) ,OTU(ALARM_ACTIVE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[This routine clears the array containing the alarm page number that have been set with the SCADA page numbers having active alarms(the page box number flaxes when an alarm is active on that page)
]]>
</Comment>
<Text>
<![CDATA[JSR(RESET_TABLE,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[THIS WILL TELL THE OPERATOR THE NUMBER OF ALARM ZONE/CHANNEL USED BY THE SYSTEM]]>
</Comment>
<Text>
<![CDATA[MOVE(9,Total_Dialer_Channel);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[CLEAR THE ARRAY INDEX COUNTER
]]>
</Comment>
<Text>
<![CDATA[CLR(indx);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[RESET ALARM REGISTER POINTED BY INDEX REGISTER 
]]>
</Comment>
<Text>
<![CDATA[LBL(Loop_Alm_1)OTU(Alarm_array[indx]);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[ADD(indx,1,indx);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[LOOP BACK UNTIL ALL CHANNELS HAVE BEEN CLEARED
]]>
</Comment>
<Text>
<![CDATA[LT(indx,Total_Dialer_Channel)JMP(Loop_Alm_1);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[CLEAR THE NUMBER OF ALARMS FROM LAST CYCLE]]>
</Comment>
<Text>
<![CDATA[CLR(total_alarm);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[CONTROLLER STATUS
 
STATUS_BITS.12 and STATUS_BITS.13 means that the controller key is in remote
]]>
</Comment>
<Text>
<![CDATA[GSV(ControllerDevice,?,Status,STATUS_BITS);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Minor Fault
]]>
</Comment>
<Text>
<![CDATA[GSV(FaultLog,?,MinorFaultBits,MinorFaultBit);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[MinorFaultBit.10 is battery faulted
 
]]>
</Comment>
<Text>
<![CDATA[XIC(MinorFaultBit.10)OTE(Battery_Fault);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Major fault
]]>
</Comment>
<Text>
<![CDATA[GSV(FaultLog,?,MajorFaultBits,MajorFaultBit);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[(*PLC_XA1 - PLC101 Progr. Fault *)
//Read the value
]]>
</Comment>
<Text>
<![CDATA[[GT(MajorFaultBit,0) ,GT(MinorFaultBit,0) NE(MinorFaultBit,1024) ]OTE(PLC_XA1.Raw_Input);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[ENTER THE MODULES IN HERE TO DETERMINE IF THERE IS A HARDWARE FAULT
ON THE PLC I/O MODULES
]]>
</Comment>
<Text>
<![CDATA[GSV(Module,DI1,FaultCode,DI1_Fault_Code)GSV(Module,DI2,FaultCode,DI2_Fault_Code)GSV(Module,DI3,FaultCode,DI3_Fault_Code)GSV(Module,DI4,FaultCode,DI4_Fault_Code)GSV(Module,DO1,FaultCode,DO1_Fault_Code)GSV(Module,AI1,FaultCode,AI1_Fault_Code)GSV(Module,AI2,FaultCode,AI2_Fault_Code)GSV(Module,AO2,FaultCode,AO2_Fault_Code)GSV(Module,AO,FaultCode,AO_Fault_Code);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[ADD ALL THE MODULES FAULT CODES 
AND
IF THE VALUE IS GREATER THAN 0 
THEN
THERE IS AT LEAST ONE MODULE FAULTED
 
]]>
</Comment>
<Text>
<![CDATA[CPT(Faulty_Modules,DI1_Fault_Code+DI2_Fault_Code+DI3_Fault_Code+DI4_Fault_Code+DO1_Fault_Code+AI1_Fault_Code+AI2_Fault_Code+AO2_Fault_Code+AO_Fault_Code);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[(*PLC_XA2 - PLC101 Hardware Fault *)
//Read the value]]>
</Comment>
<Text>
<![CDATA[NE(Faulty_Modules,0)OTE(PLC_XA2.Raw_Input);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[CALL THE DISCRETE ALARM SUBROUTINE
 
]]>
</Comment>
<Text>
<![CDATA[JSR(T1_Discrete_Alarm_Sub,0);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[CALL THE ANALOG ALARM SUBROUTINE
 
]]>
</Comment>
<Text>
<![CDATA[JSR(T1_Analog_Alarm_Sub,0);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[Reset the dialer active status
 
]]>
</Comment>
<Text>
<![CDATA[OTU(Dialer_Active);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[RESET INDEX REGISTER]]>
</Comment>
<Text>
<![CDATA[CLR(indx);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Advance to next channel
 
]]>
</Comment>
<Text>
<![CDATA[LBL(Loop_Alm_2)ADD(indx,1,indx);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[Go through all the alarms channels and set the dialer channel if an alarm  is active 
and set the dialer active bit
 
]]>
</Comment>
<Text>
<![CDATA[XIC(Alarm_array[indx-1])[OTE(Dialer_Array[indx-1]) ,OTL(Dialer_Active) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Text>
<![CDATA[LT(indx,Total_Dialer_Channel)JMP(Loop_Alm_2);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[BUZZER IS TRIGGERED FROM A NEW ALARM WITH BUZZER BEING ENABLED FOR THAT SPECIFIC ALARM
]]>
</Comment>
<Text>
<![CDATA[XIC(BUZZER_TRIGGERED)OTU(BUZZER_TRIGGERED)OTL(BUZZER_ACTIVE);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[STOP BUZZER ON]]>
</Comment>
<Text>
<![CDATA[[XIC(Operator_Alarm_Ack) ,XIC(Operator_Alarm_Reset_Dialer) ,XIC(Operator_Gen_Alm_Reset) ]OTU(BUZZER_ACTIVE);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[RESET ALARM ACTIVE BIT ON OPERATOR REQUEST OR WHEN ALL ALARMS ARE CLEARED]]>
</Comment>
<Text>
<![CDATA[[XIC(Operator_Alarm_Ack) ,XIC(Operator_Alarm_Reset_Dialer) ,XIC(Operator_Gen_Alm_Reset) ,EQ(total_alarm,0) ]OTU(ALARM_ACTIVE);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[CLEAR OPERATOR BITS
]]>
</Comment>
<Text>
<![CDATA[OTU(Operator_Alarm_Ack)OTU(Operator_Alarm_Reset_Dialer);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[FIRST CYCLE COMPLETED FOR ALARM ROUTINE
]]>
</Comment>
<Text>
<![CDATA[OTE(FirstCycle_Alarm_Control_DN);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="RESET_TABLE" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[SBR();]]>
</Line>
<Line Number="1">
<![CDATA[]]>
</Line>
<Line Number="2">
<![CDATA[]]>
</Line>
<Line Number="3">
<![CDATA[For j := 0 to 95 Do]]>
</Line>
<Line Number="4">
<![CDATA[	ALARM_PAGE_SCADA[j] :=0;]]>
</Line>
<Line Number="5">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="6">
<![CDATA[]]>
</Line>
<Line Number="7">
<![CDATA[RET();]]>
</Line>
</STContent>
</Routine>
<Routine Name="T1_Analog_Alarm_Sub" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[LIT001_HI_ALM - Wet Well Level High Limit Alarm
ALARM ENABLED BY SYSTEM LOGIC
(ON IF NOT USED)]]>
</Comment>
<Text>
<![CDATA[XIC(ON)OTE(LIT001_HI_ALM.Sys_Ena);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[LIT001_HI_ALM - Wet Well Level High Limit Alarm]]>
